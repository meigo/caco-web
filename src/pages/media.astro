---
import BaseLayout from '../layouts/BaseLayout.astro';
import mediaData from '../data/media.json';

const liveVideos = mediaData.videos.filter(v => v.type === 'live' || v.type === 'performance');
const musicVideos = mediaData.videos.filter(v => v.type === 'album');
const interviewVideos = mediaData.videos.filter(v => v.type === 'interview');

const sections = [
  { id: 'live-performances', heading: 'Live Performances', videos: liveVideos },
  { id: 'music-videos', heading: 'Music Videos', videos: musicVideos },
  { id: 'interviews', heading: 'Interviews', videos: interviewVideos },
].filter(s => s.videos.length > 0);
---

<BaseLayout
  title="Media"
  description="Watch Cacophony live performances, music videos, and interviews featuring Marty Friedman and Jason Becker."
>
  <main class="media-page">

    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <h1>Media</h1>
        <p class="hero-sub">Live performances, music videos &amp; more</p>
      </div>
    </section>

    <!-- Video Sections -->
    {sections.map(section => (
      <section class="section" aria-labelledby={`${section.id}-heading`}>
        <div class="container">
          <h2 id={`${section.id}-heading`}>{section.heading}</h2>
          <div class="video-grid">
            {section.videos.map(video => (
              <article class="video-card">
                <div class="embed-wrapper">
                  <iframe
                    src={`https://www.youtube-nocookie.com/embed/${video.id}`}
                    title={video.title}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                    referrerpolicy="strict-origin-when-cross-origin"
                  ></iframe>
                </div>
                <div class="video-info">
                  <h3>{video.title}</h3>
                  <p>{video.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))}

  </main>
</BaseLayout>

<style>
  /* ── Layout ── */
  .media-page {
    min-height: calc(100vh - var(--nav-height));
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero ── */
  .hero {
    background: linear-gradient(160deg, var(--color-surface) 0%, var(--color-bg) 100%);
    border-bottom: 1px solid var(--color-border);
    padding: 4rem 0 3rem;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .hero-sub {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    letter-spacing: 0.08em;
  }

  /* ── Sections ── */
  .section {
    padding: 4rem 0;
  }

  .section:nth-child(odd) {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Video Grid ── */
  .video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .video-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Video Card ── */
  .video-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .section:nth-child(odd) .video-card {
    background: var(--color-bg);
  }

  /* 16:9 responsive embed wrapper */
  .embed-wrapper {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #000;
  }

  .embed-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── Video Info ── */
  .video-info {
    padding: 1rem 1.25rem 1.25rem;
    flex: 1;
  }

  .video-info h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.4rem;
    line-height: 1.4;
  }

  .video-info p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
