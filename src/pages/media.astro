---
import BaseLayout from '../layouts/BaseLayout.astro';
import mediaData from '../data/media.json';

const liveVideos = mediaData.videos.filter(v => v.type === 'live' || v.type === 'performance');
const musicVideos = mediaData.videos.filter(v => v.type === 'album');
const interviewVideos = mediaData.videos.filter(v => v.type === 'interview');

const sections = [
  { id: 'live-performances', heading: 'Live Performances', videos: liveVideos },
  { id: 'music-videos', heading: 'Music Videos', videos: musicVideos },
  { id: 'interviews', heading: 'Interviews', videos: interviewVideos },
].filter(s => s.videos.length > 0);
---

<BaseLayout
  title="Media"
  description="Watch Cacophony live performances, music videos, and interviews featuring Marty Friedman and Jason Becker."
>
  <main class="media-page">

    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <p class="page-label">Cacophony</p>
        <h1 class="page-title">Media</h1>
        <p class="hero-sub">Live performances, music videos &amp; more</p>
      </div>
    </section>

    <!-- Video Sections -->
    {sections.map(section => (
      <section class="section" aria-labelledby={`${section.id}-heading`}>
        <div class="container">
          <h2 id={`${section.id}-heading`}>{section.heading}</h2>
          <div class="video-grid">
            {section.videos.map(video => (
              <article class="video-card">
                <div class="embed-wrapper">
                  <iframe
                    src={`https://www.youtube-nocookie.com/embed/${video.id}`}
                    title={video.title}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                    referrerpolicy="strict-origin-when-cross-origin"
                  ></iframe>
                </div>
                <div class="video-info">
                  <h3>{video.title}</h3>
                  <p>{video.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))}

  </main>
</BaseLayout>

<style>
  /* ── Layout ── */
  .media-page {
    min-height: calc(100vh - var(--nav-height));
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero ── */
  .hero {
    padding: 5rem 0 3.5rem;
    background:
      radial-gradient(ellipse at 50% 100%, rgba(160, 160, 160, 0.1) 0%, transparent 65%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }

  .page-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    background: linear-gradient(135deg, #fff 40%, var(--color-accent) 90%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }

  .hero-sub {
    color: var(--color-text-muted);
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    font-style: italic;
    letter-spacing: 0.03em;
  }

  /* ── Sections ── */
  .section {
    padding: 5rem 0;
  }

  .section:nth-child(odd) {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }

  .section h2::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 2.5rem;
    height: 2px;
    background: var(--color-accent);
  }

  /* ── Video Grid ── */
  .video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .video-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Video Card ── */
  .video-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition-base);
  }

  .video-card:hover {
    border-color: var(--color-accent);
  }

  .section:nth-child(odd) .video-card {
    background: var(--color-bg);
  }

  /* 16:9 responsive embed wrapper */
  .embed-wrapper {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #000;
  }

  .embed-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── Video Info ── */
  .video-info {
    padding: 1rem 1.25rem 1.25rem;
    flex: 1;
  }

  .video-info h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.4rem;
    line-height: 1.4;
  }

  .video-info p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .hero { padding: 3.5rem 0 2.5rem; }
    .section { padding: 3rem 0; }
  }
</style>
