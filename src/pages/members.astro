---
import BaseLayout from '@layouts/BaseLayout.astro';
import members from '@data/members.json';

const marty = members.find(m => m.name === 'Marty Friedman')!;
const jason = members.find(m => m.name === 'Jason Becker')!;

const supportingMembers = [
  {
    name: 'Atma Anur',
    role: 'Drums',
    bio: 'Powerhouse drummer whose tight, explosive playing anchored both Cacophony albums. His technical precision gave Friedman and Becker the rhythmic foundation to push the boundaries of speed and melody.',
    wikipedia_url: 'https://en.wikipedia.org/wiki/Atma_Anur',
  },
  {
    name: 'Jimmy Waldo',
    role: 'Keyboards',
    bio: 'Classically influenced keyboardist whose lush orchestrations on Speed Metal Symphony and Go Off! gave Cacophony\'s sound its neoclassical depth. Also contributed bass on both records.',
    wikipedia_url: null,
  },
  {
    name: 'Dave Meniketti',
    role: 'Vocals (briefly)',
    bio: 'Veteran vocalist and guitarist known for his work with Y&T, who contributed to early Cacophony sessions. His blues-infused singing provided a striking contrast to the band\'s shred intensity.',
    wikipedia_url: 'https://en.wikipedia.org/wiki/Dave_Meniketti',
  },
];
---

<BaseLayout
  title="Members"
  description="Meet Marty Friedman and Jason Becker — the founding guitarists of Cacophony — and the musicians who supported them."
>
  <main>
    <!-- Page header -->
    <section class="page-hero" aria-label="Members — page header">
      <div class="container">
        <p class="page-label">Cacophony</p>
        <h1 class="page-title">The Members</h1>
        <p class="page-sub">Two guitarists. Two worlds. One historic partnership.</p>
      </div>
    </section>

    <!-- Founding guitarists -->
    <section class="guitarists" aria-label="Founding guitarists">
      <div class="container">
        <h2 class="section-title">Founding Guitarists</h2>
        <div class="guitarist-grid">

          <!-- Marty Friedman -->
          <article class="guitarist-card guitarist-card--marty" aria-label="Marty Friedman">
            <header class="guitarist-header">
              <div class="guitarist-avatar marty-avatar" aria-hidden="true">
                <span class="avatar-initials">MF</span>
              </div>
              <div class="guitarist-meta">
                <h3 class="guitarist-name">{marty.name}</h3>
                <p class="guitarist-role">{marty.role}</p>
                <p class="guitarist-origin">American · b. {new Date(marty.birth_date).getFullYear()}</p>
              </div>
            </header>

            <div class="guitarist-body">
              <p class="guitarist-bio">{marty.bio}</p>

              <div class="guitarist-tags">
                <h4 class="tags-label">Notable skills</h4>
                <ul class="tags" role="list">
                  <li>Eastern Scales</li>
                  <li>Neoclassical</li>
                  <li>Shred</li>
                  <li>Melodic Lead</li>
                </ul>
              </div>

              <div class="guitarist-career">
                <h4 class="career-label">Post-Cacophony highlights</h4>
                <ul class="career-list" role="list">
                  {marty.associated_acts.filter(a => a !== 'Cacophony').map(act => (
                    <li>{act}</li>
                  ))}
                  <li>Relocated to Japan — TV personality &amp; recording artist</li>
                </ul>
              </div>

              <a
                href={marty.wikipedia_url}
                class="wiki-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${marty.name} on Wikipedia (opens in new tab)`}
              >
                Wikipedia ↗
              </a>
            </div>
          </article>

          <!-- Jason Becker -->
          <article class="guitarist-card guitarist-card--jason" aria-label="Jason Becker">
            <header class="guitarist-header">
              <div class="guitarist-avatar jason-avatar" aria-hidden="true">
                <span class="avatar-initials">JB</span>
              </div>
              <div class="guitarist-meta">
                <h3 class="guitarist-name">{jason.name}</h3>
                <p class="guitarist-role">{jason.role}</p>
                <p class="guitarist-origin">American · b. {new Date(jason.birth_date).getFullYear()}</p>
              </div>
            </header>

            <div class="guitarist-body">
              <p class="guitarist-bio">{jason.bio}</p>

              <div class="guitarist-tags">
                <h4 class="tags-label">Notable skills</h4>
                <ul class="tags" role="list">
                  <li>Neoclassical</li>
                  <li>Shred</li>
                  <li>Sweep Picking</li>
                  <li>Legato</li>
                </ul>
              </div>

              <div class="guitarist-career">
                <h4 class="career-label">Post-Cacophony highlights</h4>
                <ul class="career-list" role="list">
                  {jason.associated_acts.filter(a => a !== 'Cacophony').map(act => (
                    <li>{act}</li>
                  ))}
                  <li>Continued composing after ALS diagnosis via eye-tracking system</li>
                </ul>
              </div>

              <a
                href={jason.wikipedia_url}
                class="wiki-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${jason.name} on Wikipedia (opens in new tab)`}
              >
                Wikipedia ↗
              </a>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- Supporting members -->
    <section class="supporting" aria-label="Supporting members">
      <div class="container">
        <h2 class="section-title">Supporting Members</h2>
        <div class="supporting-grid">
          {supportingMembers.map(member => (
            <article class="supporting-card" aria-label={member.name}>
              <div class="supporting-header">
                <h3 class="supporting-name">{member.name}</h3>
                <span class="supporting-role">{member.role}</span>
              </div>
              <p class="supporting-bio">{member.bio}</p>
              {member.wikipedia_url && (
                <a
                  href={member.wikipedia_url}
                  class="wiki-link wiki-link--sm"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${member.name} on Wikipedia (opens in new tab)`}
                >
                  Wikipedia ↗
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Design tokens ── */
  :root {
    --c-bg: #000000;
    --c-surface: #111111;
    --c-surface-2: #1a1a1a;
    --c-border: #2a2a2a;
    --c-accent: #909090;
    --c-accent-bright: #b8b8b8;
    --c-gold: #a0a0a0;
    --c-text: #f0f0f0;
    --c-muted: #666666;
    --font-heading: 'Space Mono', 'Courier New', monospace;
    --font-body: 'Roboto Mono', 'Courier New', monospace;
    --max-w: 1100px;
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; scroll-behavior: smooth; }
  body { background: var(--c-bg); color: var(--c-text); font-family: var(--font-body); line-height: 1.6; }
  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-text);
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }
  .section-title::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 2.5rem;
    height: 2px;
    background: var(--c-accent);
  }

  /* ── Page hero ── */
  .page-hero {
    padding: 5rem 0 3.5rem;
    background:
      radial-gradient(ellipse at 50% 100%, rgba(180, 180, 180, 0.06) 0%, transparent 65%),
      var(--c-bg);
    border-bottom: 1px solid var(--c-border);
  }
  .page-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--c-accent);
    margin-bottom: 0.75rem;
  }
  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    background: linear-gradient(135deg, #fff 40%, #888888 90%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }
  .page-sub {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    color: var(--c-muted);
    font-style: italic;
    letter-spacing: 0.03em;
  }

  /* ── Guitarist grid ── */
  .guitarists {
    padding: 5rem 0;
  }
  .guitarist-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .guitarist-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
  }
  .guitarist-card--marty {
    border-top: 3px solid var(--c-accent);
  }
  .guitarist-card--jason {
    border-top: 3px solid var(--c-gold);
  }
  .guitarist-card:hover {
    border-color: var(--c-accent);
  }
  .guitarist-card--jason:hover {
    border-color: var(--c-gold);
  }

  .guitarist-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.75rem 1.75rem 0;
  }

  .guitarist-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .marty-avatar {
    background: radial-gradient(135deg, rgba(180, 180, 180, 0.2), rgba(180, 180, 180, 0.05));
    border: 2px solid rgba(180, 180, 180, 0.4);
  }
  .jason-avatar {
    background: radial-gradient(135deg, rgba(180, 180, 180, 0.2), rgba(180, 180, 180, 0.05));
    border: 2px solid rgba(180, 180, 180, 0.4);
  }
  .avatar-initials {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 900;
    color: var(--c-text);
    letter-spacing: 0.05em;
  }

  .guitarist-name {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--c-text);
    margin-bottom: 0.15rem;
  }
  .guitarist-role {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-accent);
    margin-bottom: 0.15rem;
  }
  .guitarist-card--jason .guitarist-role {
    color: var(--c-gold);
  }
  .guitarist-origin {
    font-size: 0.78rem;
    color: var(--c-muted);
  }

  .guitarist-body {
    padding: 1.5rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex: 1;
  }

  .guitarist-bio {
    font-size: 0.92rem;
    color: var(--c-muted);
    line-height: 1.8;
  }

  .tags-label,
  .career-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: 0.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tags li {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--c-border);
    color: var(--c-muted);
    background: var(--c-surface-2);
  }

  .career-list {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .career-list li {
    font-size: 0.85rem;
    color: var(--c-muted);
    padding-left: 0.9rem;
    position: relative;
  }
  .career-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--c-accent);
  }
  .guitarist-card--jason .career-list li::before {
    color: var(--c-gold);
  }

  .wiki-link {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-accent);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    margin-top: auto;
    transition: color 0.15s;
    align-self: flex-start;
  }
  .guitarist-card--jason .wiki-link {
    color: var(--c-gold);
  }
  .wiki-link:hover {
    color: var(--c-accent-bright);
  }
  .wiki-link--sm {
    font-size: 0.75rem;
    color: var(--c-accent);
  }
  .wiki-link--sm:hover {
    color: var(--c-accent-bright);
  }

  /* ── Supporting members ── */
  .supporting {
    padding: 5rem 0 6rem;
    background: var(--c-surface);
    border-top: 1px solid var(--c-border);
  }
  .supporting-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .supporting-card {
    background: var(--c-surface-2);
    border: 1px solid var(--c-border);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s;
  }
  .supporting-card:hover {
    border-color: var(--c-accent);
  }
  .supporting-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .supporting-name {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--c-text);
  }
  .supporting-role {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-accent);
  }
  .supporting-bio {
    font-size: 0.87rem;
    color: var(--c-muted);
    line-height: 1.75;
    flex: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .guitarist-grid { grid-template-columns: 1fr; }
    .supporting-grid { grid-template-columns: 1fr; }
    .page-hero { padding: 3.5rem 0 2.5rem; }
  }
</style>
